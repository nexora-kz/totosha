{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.55 }],
        "categories:accessibility": ["warn", { "minScore": 0.75 }],
        "categories:best-practices": ["warn", { "minScore": 0.75 }],
        "categories:seo": ["warn", { "minScore": 0.75 }]
      }
    }
  }
}
